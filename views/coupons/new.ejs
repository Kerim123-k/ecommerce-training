<%- include('../shared/header', { title: 'New Coupon' }) %>

<h1>New coupon</h1>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form id="couponForm" method="POST" action="/admin/coupons">

  <!-- DETAILS -->
  <section class="card pad page-card">
    <div class="section-title">Details</div>

    <div class="form-grid cols-2">
      <div class="field">
        <label for="code">Code*</label>
        <input id="code" name="code" value="<%= (values && values.code) || '' %>" required placeholder="WELCOME10" autocomplete="off">
        <div class="help">Shown to customers during checkout.</div>
      </div>

      <div class="field">
        <label for="type">Type*</label>
        <select id="type" name="type" required>
          <option value="percent" <%= (values && values.type)==='percent' ? 'selected' : '' %>>Percent (%)</option>
          <option value="amount"  <%= (values && values.type)==='amount'  ? 'selected' : '' %>>Fixed amount (₺)</option>
        </select>
      </div>

      <!-- Value (percent) -->
      <div class="field" id="valuePercentWrap">
        <label for="valuePercent">Value*</label>
        <input id="valuePercent" type="number" step="0.01" min="0" name="value" value="<%= (values && values.type)==='percent' ? (values.value || '') : '' %>">
        <div class="help">Enter the percentage discount (e.g., 10 for 10%).</div>
      </div>

      <!-- Value (amount, with currency prefix) -->
      <div class="field" id="valueAmountWrap" style="display:none;">
        <label for="valueAmount">Value*</label>
        <div class="input-prefix">
          <span>₺</span>
          <input id="valueAmount" type="number" step="0.01" min="0" name="value" value="<%= (values && values.type)==='amount' ? (values.value || '') : '' %>">
        </div>
        <div class="help">Enter the fixed amount to subtract from the order.</div>
      </div>

      <div class="field">
        <label for="minSubtotal">Min subtotal</label>
        <div class="input-prefix">
          <span>₺</span>
          <input id="minSubtotal" type="number" step="0.01" min="0" name="minSubtotal" value="<%= (values && values.minSubtotal) || '' %>">
        </div>
        <div class="help">Optional. Require a minimum order subtotal.</div>
      </div>

      <div class="field">
        <label>Active</label>
        <div class="switch-wrap">
          <input id="active" class="switch-input" type="checkbox" name="active" <%= (values && 'active' in values) ? (values.active ? 'checked' : '') : 'checked' %> >
          <label for="active" class="switch-ui" aria-hidden="true"></label>
          <label for="active" class="switch-text">Coupon is active</label>
        </div>
      </div>

      <div class="field field--full">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="2"><%= (values && values.notes) || '' %></textarea>
      </div>
    </div>
  </section>

  <!-- SCHEDULE -->
  <section class="card pad page-card">
    <div class="section-title">Schedule</div>
    <div class="form-grid cols-2">
      <div class="field">
        <label for="startsAt">Starts at</label>
        <input id="startsAt" type="date" name="startsAt" value="<%= (values && values.startsAt) || '' %>">
      </div>
      <div class="field">
        <label for="endsAt">Ends at</label>
        <input id="endsAt" type="date" name="endsAt" value="<%= (values && values.endsAt) || '' %>">
      </div>

      <div class="field">
        <label for="maxUses">Max uses</label>
        <input id="maxUses" type="number" min="0" name="maxUses" value="<%= (values && values.maxUses) || '' %>">
        <div class="help">Optional cap on total redemptions.</div>
      </div>

      <div class="field field--full">
        <div class="help" id="previewLine" style="font-weight:600;"></div>
      </div>
    </div>
  </section>

  <!-- STICKY ACTIONS -->
  <div class="action-bar">
    <div class="action-bar__inner">
      <button class="btn btn--brand" type="submit">Create</button>
      <a class="btn" href="/admin/coupons">Cancel</a>
    </div>
  </div>
</form>

<script>
(function(){
  const $ = (s, r=document) => r.querySelector(s);

  const typeSel   = $('#type');
  const codeIn    = $('#code');
  const valPct    = $('#valuePercent');
  const valAmt    = $('#valueAmount');
  const wrapPct   = $('#valuePercentWrap');
  const wrapAmt   = $('#valueAmountWrap');
  const minSub    = $('#minSubtotal');
  const startIn   = $('#startsAt');
  const endIn     = $('#endsAt');
  const activeIn  = $('#active');
  const preview   = $('#previewLine');

  // Formatters
  const fmtTRY = new Intl.NumberFormat('tr-TR', { style:'currency', currency:'TRY', minimumFractionDigits:2 });

  function toggleValueInput(){
    const t = typeSel.value;
    if (t === 'amount'){
      wrapAmt.style.display = '';
      wrapPct.style.display = 'none';
      // move value to the visible input if needed
      if (!valAmt.value && valPct.value){ valAmt.value = valPct.value; }
    } else {
      wrapPct.style.display = '';
      wrapAmt.style.display = 'none';
      if (!valPct.value && valAmt.value){ valPct.value = valAmt.value; }
    }
    updatePreview();
  }

  function updatePreview(){
    const code   = (codeIn.value || '').trim().toUpperCase();
    const type   = typeSel.value;
    const value  = parseFloat((type === 'amount' ? valAmt.value : valPct.value) || 0);
    const min    = parseFloat(minSub.value || 0);
    const s      = startIn.value;
    const e      = endIn.value;
    const act    = !!activeIn.checked;

    let parts = [];
    if (code) parts.push(code);

    if (type === 'amount'){
      parts.push(value ? (fmtTRY.format(value) + ' off') : 'Amount off');
    } else {
      parts.push(value ? (value + '% off') : '% off');
    }

    if (!isNaN(min) && min > 0) parts.push('min ' + fmtTRY.format(min));
    if (s || e) parts.push((s || 'now') + ' → ' + (e || 'no end'));
    parts.push(act ? 'Active' : 'Inactive');

    preview.textContent = parts.join(' • ');
  }

  function clampDates(){
    if (startIn.value && endIn.value && startIn.value > endIn.value){
      endIn.value = startIn.value;
    }
  }

  // Events
  [typeSel, codeIn, valPct, valAmt, minSub, startIn, endIn, activeIn].forEach(el=>{
    el && el.addEventListener('input', function(){
      if (this === typeSel) toggleValueInput();
      if (this === startIn || this === endIn) clampDates();
      updatePreview();
    });
  });

  // init
  toggleValueInput();
  clampDates();
  updatePreview();
})();
</script>

<%- include('../shared/footer') %>
