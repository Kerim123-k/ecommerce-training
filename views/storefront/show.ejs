<%- include('../shared/header') %>

<%
  // ---- Image normalization (defensive) ----
  let img =
    (Array.isArray(product.images) && product.images[0]) ||
    product.image ||
    'https://picsum.photos/seed/product/1200/800';
  if (img && img.startsWith('//')) img = 'https:' + img;
  if (img && img.startsWith('http://')) img = img.replace(/^http:\/\//, 'https://');

  // ---- Stock flags (fallbacks if controller didn't pass) ----
  const qty           = Number(product.stockQty || 0);
  const inStockLocal  = qty > 0;
  const lowStockLocal = qty > 0 && qty <= 5;

  // ---- Reviews data (safe defaults) ----
  const reviewList =
    (typeof reviews !== 'undefined' && Array.isArray(reviews)) ? reviews : [];
  const reviewCountSafe =
    (typeof reviewCount === 'number') ? reviewCount : reviewList.length;

  let avgSafe = 0;
  if (typeof avgRating === 'number') {
    avgSafe = avgRating;
  } else if (reviewList.length) {
    const sum = reviewList.reduce((s,r) => s + Number(r.rating || 0), 0);
    avgSafe = sum / reviewList.length;
  }
  avgSafe = Number(avgSafe.toFixed(1));
  const solidStars = Math.max(0, Math.min(5, Math.round(avgSafe)));

  // ---- Related products (safe default) ----
  const relatedList =
    (typeof related !== 'undefined' && Array.isArray(related)) ? related : [];

  // ---- Wishlist state for this product ----
  const inWish = Array.isArray(wishlistIds) && wishlistIds.includes(String(product._id));
%>

<style>
  .heart {
    background: transparent;
    border: 1px solid #ddd;
    line-height: 1;
    padding: 6px 10px;
    font-size: 18px;
    color: #999;              /* gray by default */
    cursor: pointer;
    border-radius: 8px;
  }
  .heart.is-active {
    color: #e0245e;           /* red when active */
    border-color: #e0245e33;
    background: #e0245e10;
  }
</style>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="alert alert-success" style="margin-bottom:12px;"><%= flash %></div>
<% } %>

<div class="product" style="display:grid; grid-template-columns:1fr 1fr; gap:24px; align-items:start;">
  <div class="product__media">
    <img src="<%= img %>" alt="<%= product.title %>" style="max-width:100%; height:auto; border-radius:12px;" />
  </div>

  <div class="product__info">
    <h1 style="margin:0 0 6px 0;"><%= product.title %></h1>
    <div class="muted" style="margin-bottom:8px;">SKU <%= product.sku %></div>

    <!-- Rating summary -->
    <div style="margin:8px 0;">
      <% if (reviewCountSafe > 0) { %>
        <span aria-label="Average rating">
          <% for (let s=0; s<solidStars; s++) { %>★<% } %><% for (let s=solidStars; s<5; s++) { %>☆<% } %>
        </span>
        <span class="muted"> <%= avgSafe %>/5 · <%= reviewCountSafe %> review<%= reviewCountSafe===1?'':'s' %></span>
      <% } else { %>
        <span class="muted">No reviews yet</span>
      <% } %>
    </div>

    <% if ((typeof lowStock !== 'undefined' ? lowStock : lowStockLocal)) { %>
      <div class="pill pill--warn" style="display:inline-block; padding:4px 10px; border-radius:999px; background:#fff3cd; color:#8a6d3b; margin:8px 0;">
        Low stock: <%= qty %> left
      </div>
    <% } %>

    <div class="price" style="margin:12px 0; font-size:1.25rem;">₺ <%= Number(product.price || 0).toFixed(2) %></div>

    <!-- Actions row -->
    <div class="actions" style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
      <% if ((typeof inStock !== 'undefined' ? inStock : inStockLocal)) { %>
        <!-- Add to cart (with qty) -->
        <form method="POST" action="/cart/add/<%= product._id %>" style="display:flex; gap:10px; align-items:center;">
          <label class="muted">Qty
            <input
              type="number"
              name="qty"
              min="1"
              max="<%= Math.max(1, qty) %>"
              value="1"
              style="width:70px; margin-left:6px;"
              required>
          </label>
          <button class="btn btn--brand" type="submit">Add to cart</button>
        </form>

        <!-- ❤️ Wishlist toggle (AJAX) -->
        <button
          class="btn heart <%= inWish ? 'is-active' : '' %>"
          type="button"
          data-wish-toggle
          data-id="<%= product._id %>"
          aria-label="Add to wishlist">
          ♥
        </button>

        <noscript>
          <form method="POST" action="/wishlist/add/<%= product._id %>" style="display:inline;">
            <button class="btn" type="submit">♥</button>
          </form>
        </noscript>
      <% } else { %>
        <button class="btn" type="button" disabled>Out of stock</button>
      <% } %>

      <a class="btn" href="/products">Back to shop</a>
    </div>
  </div>
</div>

<hr style="margin:24px 0;">

<!-- Reviews -->
<section>
  <h2 style="margin-bottom:12px;">Reviews</h2>

  <% if (!reviewList.length) { %>
    <p class="muted">No one has reviewed this product yet.</p>
  <% } else { %>
    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;">
      <% reviewList.forEach(r => {
           const rStars = Math.max(0, Math.min(5, Number(r.rating || 0)));
      %>
        <li style="border:1px solid #eee; border-radius:12px; padding:12px;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
              <strong>
                <% for (let s=0; s<rStars; s++) { %>★<% } %>
                <% for (let s=rStars; s<5; s++) { %>☆<% } %>
              </strong>
              <span class="muted" style="margin-left:8px;">
                <%= r.customerName || r.customerEmail || 'Anonymous' %>
              </span>
            </div>
            <div class="muted"><%= new Date(r.createdAt).toLocaleDateString() %></div>
          </div>
          <% if (r.title) { %>
            <div style="margin-top:6px; font-weight:600;"><%= r.title %></div>
          <% } %>
            <div style="margin-top:6px; white-space:pre-wrap;"><%= r.body || '' %></div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<hr style="margin:24px 0;">

<!-- Related products -->
<% if (relatedList.length) { %>
  <section>
    <h2 style="margin-bottom:12px;">Related products</h2>
    <div class="grid">
      <% relatedList.forEach(p => {
           let rimg = '';
           if (Array.isArray(p.images) && p.images[0]) rimg = p.images[0];
           else if (typeof p.images === 'string' && p.images.trim()) rimg = p.images.trim();
           else if (p.image) rimg = String(p.image);
           if (!rimg) rimg = 'https://upload.wikimedia.org/wikipedia/commons/6/6e/Basketball.png';
           if (rimg.startsWith('//')) rimg = 'https:' + rimg;
           if (rimg.startsWith('http://')) rimg = rimg.replace(/^http:\/\//, 'https://');

           const href = (p.slug && String(p.slug).trim()) ? '/p/' + p.slug : '/products/id/' + p._id;
           const avg = Number(p.ratingAvg || 0);
           const cnt = Number(p.ratingCount || 0);
           const stars = Math.max(0, Math.min(5, Math.round(avg)));
      %>
        <div class="card">
          <a href="<%= href %>"><img src="<%= rimg %>" alt="<%= p.title %>"></a>
          <div class="pad">
            <h3><a href="<%= href %>"><%= p.title %></a></h3>
            <div class="muted">SKU <%= p.sku %></div>
            <div class="price">₺ <%= Number(p.price || 0).toFixed(2) %></div>
            <div class="muted" style="margin-top:4px;">
              <% if (cnt > 0) { %>
                <span aria-label="Rating">
                  <% for (let s=0; s<stars; s++) { %>★<% } %><% for (let s=stars; s<5; s++) { %>☆<% } %>
                </span>
                <span>(<%= cnt %>)</span>
              <% } else { %>
                <span>☆ ☆ ☆ ☆ ☆ (0)</span>
              <% } %>
            </div>
          </div>

          <div class="actions">
            <form method="POST" action="/cart/add/<%= p._id %>" style="display:inline;">
              <input type="hidden" name="qty" value="1">
              <button class="btn btn--brand" type="submit">Add to cart</button>
            </form>
            <a href="<%= href %>" class="btn">Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<script>
  (function () {
    const btn = document.querySelector('[data-wish-toggle]');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      try {
        const res = await fetch(`/wishlist/toggle/${encodeURIComponent(id)}`, {
          method: 'POST',
          headers: { 'X-Requested-With': 'fetch' }
        });
        if (!res.ok) return;
        const data = await res.json();
        if (data.inWishlist) btn.classList.add('is-active');
        else btn.classList.remove('is-active');

        const badge = document.querySelector('[data-wishlist-count]');
        if (badge) badge.textContent = data.count;
      } catch (_) { /* ignore */ }
    });
  })();
</script>

<%- include('../shared/footer') %>
