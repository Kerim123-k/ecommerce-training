<%- include('../shared/header', { title: (product && product.title) || 'Product' }) %>

<%
  // Normalize images for gallery
  const images = Array.isArray(product?.images) && product.images.length
    ? product.images
    : (product?.image ? [product.image] : []);

  // SAFE compute: whether this item is in the wishlist
  let wished = false;
  if (typeof isWished !== 'undefined') {
    wished = !!isWished;
  } else if (typeof wishIds !== 'undefined' && Array.isArray(wishIds)) {
    wished = wishIds.map(String).includes(String(product._id));
  }
%>

<style>
  .wish-wrap { display:flex; align-items:center; gap:12px; margin:8px 0 14px; }
  .wish-btn {
    width:44px; height:44px; border-radius:999px;
    display:inline-flex; align-items:center; justify-content:center;
    background:#fff; border:1px solid #e5e7eb; cursor:pointer;
    transition:transform .06s ease, border-color .15s ease;
  }
  .wish-btn svg { width:22px; height:22px; fill:transparent; stroke:#e11d48; stroke-width:2.2; }
  .wish-btn.active svg { fill:#ef4444; stroke:#ef4444; }
  .wish-btn:active { transform:scale(.96); }
  @media (hover:hover){ .wish-btn:hover { border-color:#ef4444; } }
</style>

<section class="product-show">
  <div class="product-show__gallery">
    <%- include('../shared/product_gallery', { item: product, images }) %>
  </div>

  <aside class="product-show__info">
    <h1><%= product.title %></h1>
    <p class="muted">SKU <%= product.sku %></p>

    <div class="wish-wrap">
      <p class="price-lg" style="margin:0;">₺ <%= Number(product.price || 0).toFixed(2) %></p>
      <form class="wish-form" method="POST" action="/wishlist/toggle/<%= product._id %>">
        <button
          type="submit"
          class="wish-btn <%= wished ? 'active' : '' %>"
          aria-pressed="<%= wished ? 'true' : 'false' %>"
          aria-label="<%= wished ? 'Remove from wishlist' : 'Add to wishlist' %>">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21s-7.2-4.4-9.6-8.4C.9 9.3 2.1 6.2 5 5c1.8-.8 3.9-.3 5.2 1 1.4-1.3 3.4-1.8 5.2-1 2.9 1.2 4.1 4.3 2.6 7.6C19.2 16.6 12 21 12 21z"/>
          </svg>
        </button>
      </form>
    </div>

    <form method="POST" action="/cart/add/<%= product._id %>" class="hstack" style="gap:10px;">
      <input type="number" name="qty" value="1" min="1" class="input" style="width:90px;">
      <button class="btn btn--brand" type="submit">Add to cart</button>
      <a class="btn" href="/products">Back to shop</a>
    </form>
  </aside>
</section>

<section class="block" style="margin-top:28px;">
  <h2>Reviews</h2>
  <p class="muted">No one has reviewed this product yet.</p>
</section>

<script>
  // Toggle heart instantly; POST in background, fall back to form submit on error.
  document.querySelectorAll('.wish-form').forEach(function (f) {
    f.addEventListener('submit', function (e) {
      var btn = f.querySelector('.wish-btn');
      if (!window.fetch) return; // fallback: normal POST
      e.preventDefault();
      fetch(f.action, {
        method: 'POST',
        headers: { 'X-Requested-With': 'fetch' }
      }).then(function () {
        btn.classList.toggle('active');
        btn.setAttribute('aria-pressed', btn.classList.contains('active') ? 'true' : 'false');
      }).catch(function () {
        f.submit(); // fallback
      });
    });
  });
</script>

<%- include('../shared/footer') %>
