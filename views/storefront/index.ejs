<%- include('../shared/header', { title: 'Storefront' }) %>

<h1 style="margin:8px 0 6px;">Storefront</h1>

<form method="GET" class="filters">
  <input type="text" name="q" value="<%= q || '' %>" placeholder="Search products…">
  <select name="cat">
    <option value="">All categories</option>
    <% (cats || []).forEach(c => { %>
      <option value="<%= c._id %>" <%= String(cat||'')===String(c._id)?'selected':'' %>><%= c.name %></option>
    <% }) %>
  </select>
  <select name="sort" onchange="this.form.submit()">
    <option value="new" <%= sort==='new' ? 'selected' : '' %>>Newest</option>
    <option value="price_asc" <%= sort==='price_asc' ? 'selected' : '' %>>Price: Low to High</option>
    <option value="price_desc" <%= sort==='price_desc' ? 'selected' : '' %>>Price: High to Low</option>
  </select>
  <div style="grid-column:1 / -1; display:flex; gap:8px;">
    <button class="btn btn--brand" type="submit">Apply</button>
    <% if (q || cat || (sort && sort!=='new')) { %>
      <a class="btn" href="/products">Reset</a>
    <% } %>
  </div>
</form>

<% if (!products || !products.length) { %>
  <div class="card pad">
    <strong>No products found.</strong>
    <div class="muted">Try clearing filters or searching something else.</div>
  </div>
<% } else { %>
  <div class="product-grid">
    <% products.forEach(p => {
         const img = (Array.isArray(p.images) && p.images.length) ? p.images[0] : (p.image || '');
         const href = p.slug ? ('/p/' + p.slug) : ('/products/id/' + p._id);
    %>
      <article class="product-card">
        <a class="thumb" href="<%= href %>">
          <% if (img) { %>
            <img
              src="<%= img %>"
              alt="<%= p.title %>"
              loading="lazy"
              decoding="async"
            >
          <% } else { %>
            <img
              src="https://via.placeholder.com/600x450?text=No+Image"
              alt=""
              loading="lazy"
              decoding="async"
            >
          <% } %>
        </a>
        <div class="body">
          <a class="title" href="<%= href %>"><%= p.title %></a>
          <div class="price">₺ <%= Number(p.price || 0).toFixed(2) %></div>
          <div class="actions">
            <form method="POST" action="/cart/add/<%= p._id %>">
              <input type="hidden" name="qty" value="1">
              <button class="btn btn--brand" type="submit">Add to cart</button>
            </form>
            <a class="btn" href="<%= href %>">View</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('../shared/footer') %>
