<%- include('../shared/header', { title: 'Storefront' }) %>

<style>
  /* Wishlist heart */
  .wishlist-toggle {
    position:absolute; top:10px; right:10px; z-index:2;
    display:inline-flex; align-items:center; justify-content:center;
    width:44px; height:44px; border-radius:999px;
    background:rgba(255,255,255,0.92);
    box-shadow:0 4px 12px rgba(0,0,0,.12);
    border:1px solid rgba(0,0,0,.06);
  }
  .wishlist-toggle:hover { background:#fff; }
  .wishlist-toggle svg { width:26px; height:26px; display:block; }
  .wishlist-toggle svg path {
    stroke:#e11d48; /* rose-600 */
    stroke-width:2px;
    fill:transparent;
    transition:fill .18s ease, stroke .18s ease, transform .18s ease;
  }
  .wishlist-toggle.is-active svg path { fill:#e11d48; stroke:#e11d48; }
  .wishlist-toggle:active svg path { transform:scale(.92); }

  /* Card positioning */
  .product-card { position:relative; }
</style>

<h1 style="margin:8px 0 6px;">Storefront</h1>

<form method="GET" class="filters">
  <input type="text" name="q" value="<%= q || '' %>" placeholder="Search products…">
  <select name="cat">
    <option value="">All categories</option>
    <% (cats || []).forEach(c => { %>
      <option value="<%= c._id %>" <%= String(cat||'')===String(c._id)?'selected':'' %>><%= c.name %></option>
    <% }) %>
  </select>
  <select name="sort" onchange="this.form.submit()">
    <option value="new" <%= sort==='new' ? 'selected' : '' %>>Newest</option>
    <option value="price_asc" <%= sort==='price_asc' ? 'selected' : '' %>>Price: Low to High</option>
    <option value="price_desc" <%= sort==='price_desc' ? 'selected' : '' %>>Price: High to Low</option>
  </select>
  <div style="grid-column:1 / -1; display:flex; gap:8px;">
    <button class="btn btn--brand" type="submit">Apply</button>
    <% if (q || cat || (sort && sort!=='new')) { %>
      <a class="btn" href="/products">Reset</a>
    <% } %>
  </div>
</form>

<% if (!products || !products.length) { %>
  <div class="card pad">
    <strong>No products found.</strong>
    <div class="muted">Try clearing filters or searching something else.</div>
  </div>
<% } else { %>
  <% /* If your controller can pass the user's wishlist product IDs, put them into wishIds */ %>
  <% const wishIds = (locals.wishIds || []).map(String); %>

  <div class="product-grid">
    <% products.forEach(p => {
         const img = (Array.isArray(p.images) && p.images.length) ? p.images[0] : (p.image || '');
         const href = p.slug ? ('/p/' + p.slug) : ('/products/id/' + p._id);
         const wished = wishIds.includes(String(p._id));
    %>
      <article class="product-card">
        <!-- Heart (progressive enhancement: form posts, JS makes it instant) -->
        <form class="js-wishlist-form" action="/wishlist/toggle/<%= p._id %>" method="POST">
          <button
            type="submit"
            class="wishlist-toggle <%= wished ? 'is-active' : '' %>"
            aria-label="Toggle wishlist"
            data-id="<%= p._id %>">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.1 21.35l-1.1-.99C5.14 15.24 2 12.36 2 8.98 2 6.5 4 4.5 6.48 4.5c1.54 0 3.04.75 3.96 1.97A5.05 5.05 0 0 1 14.4 4.5C16.9 4.5 19 6.5 19 8.98c0 3.38-3.14 6.26-8.02 11.38l-1 1z"/>
            </svg>
          </button>
        </form>

        <a class="thumb" href="<%= href %>">
          <% if (img) { %>
            <img
              src="<%= img %>"
              alt="<%= p.title %>"
              loading="lazy"
              decoding="async"
            >
          <% } else { %>
            <img
              src="https://via.placeholder.com/600x450?text=No+Image"
              alt=""
              loading="lazy"
              decoding="async"
            >
          <% } %>
        </a>

        <div class="body">
          <a class="title" href="<%= href %>"><%= p.title %></a>
          <div class="price">₺ <%= Number(p.price || 0).toFixed(2) %></div>
          <div class="actions">
            <form method="POST" action="/cart/add/<%= p._id %>">
              <input type="hidden" name="qty" value="1">
              <button class="btn btn--brand" type="submit">Add to cart</button>
            </form>
            <a class="btn" href="<%= href %>">View</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<script>
  // Optional instant toggle (falls back to normal form post if fetch fails)
  (function () {
    function attach(el) {
      el.addEventListener('submit', async function (e) {
        e.preventDefault();
        const btn = this.querySelector('.wishlist-toggle');
        const id = btn?.dataset.id;
        if (!id) return this.submit(); // fallback

        try {
          const res = await fetch(this.action, {
            method: 'POST',
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin'
          });
          if (res.ok) {
            // Expect { ok:true, inWishlist:boolean } (gracefully toggle otherwise)
            let data = {};
            try { data = await res.json(); } catch {}
            const active = (typeof data.inWishlist === 'boolean')
              ? data.inWishlist
              : !btn.classList.contains('is-active');
            btn.classList.toggle('is-active', active);
          } else {
            this.submit(); // fallback to full POST
          }
        } catch {
          this.submit(); // network issue: fallback
        }
      });
    }
    document.querySelectorAll('.js-wishlist-form').forEach(attach);
  })();
</script>

<%- include('../shared/footer') %>
