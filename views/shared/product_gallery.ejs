<%
  const it   = (typeof item !== 'undefined' && item) ? item : {};
  const imgs = (Array.isArray(images) && images.length) ? images : (it.image ? [it.image] : []);
%>

<div class="product-gallery">
  <div class="pg-main">
    <% if (imgs.length) { %>
      <img src="<%= imgs[0] %>" alt="<%= it.title || '' %>" loading="eager">
    <% } else { %>
      <img src="https://via.placeholder.com/800x600?text=No+Image" alt="">
    <% } %>
  </div>

  <% if (imgs.length > 1) { %>
    <div class="pg-thumbs">
      <% imgs.forEach((src, i) => { %>
        <button type="button" class="pg-thumb <%= i === 0 ? 'is-active' : '' %>" data-src="<%= src %>">
          <img src="<%= src %>" alt="" loading="lazy">
        </button>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
(function () {
  const root = document.currentScript.previousElementSibling;
  if (!root) return;
  const main = root.querySelector('.pg-main img');
  root.querySelectorAll('.pg-thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src');
      if (!src || !main) return;
      main.src = src;
      root.querySelectorAll('.pg-thumb.is-active').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });
})();
</script>
