<%
  const it   = (typeof item !== 'undefined' && item) ? item : {};
  const raw  = (Array.isArray(images) && images.length) ? images : (it.image ? [it.image] : []);
  const imgs = raw.filter(Boolean);

  const titleSafe     = encodeURIComponent(it.title || 'Image');
  const mainFallback  = `https://placehold.co/800x600/png?text=${titleSafe}`;
  const thumbFallback = `https://placehold.co/160x120/png?text=${titleSafe}`;
%>

<div class="product-gallery">
  <div class="pg-main">
    <img
      src="<%= imgs[0] || mainFallback %>"
      alt="<%= it.title || '' %>"
      loading="eager"
      decoding="async"
      referrerpolicy="no-referrer"
      crossorigin="anonymous"
      onerror="this.onerror=null; this.src='<%= mainFallback %>';"
    >
  </div>

  <% if (imgs.length > 1) { %>
    <div class="pg-thumbs">
      <% imgs.forEach((src, i) => { %>
        <button type="button" class="pg-thumb <%= i === 0 ? 'is-active' : '' %>" data-src="<%= src %>">
          <img
            src="<%= src %>"
            alt=""
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
            crossorigin="anonymous"
            onerror="this.onerror=null; this.src='<%= thumbFallback %>';"
          >
        </button>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
(function () {
  const root = document.currentScript.previousElementSibling;
  if (!root) return;
  const main = root.querySelector('.pg-main img');
  root.querySelectorAll('.pg-thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src');
      if (!src || !main) return;
      main.src = src;
      root.querySelectorAll('.pg-thumb.is-active').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });
})();
</script>
