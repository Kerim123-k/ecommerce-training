<!-- views/shared/product_gallery.ejs -->
<%
// expects: { item, images }
// images: array of urls; item: product doc (used only for alt text)
const imgs = Array.isArray(images) && images.length
  ? images
  : (item && item.image ? [item.image] : []);
%>

<style>
  .pg-wrap{display:grid;grid-template-columns:1fr;gap:14px}
  .pg-main{width:100%;border-radius:8px;overflow:hidden;background:#fff}
  .pg-main img{display:block;width:100%;height:auto}
  .pg-thumbs{display:flex;gap:10px;flex-wrap:wrap}
  .pg-thumb{border:0;padding:0;background:#fff;border-radius:8px;cursor:pointer;outline:none}
  .pg-thumb img{width:92px;height:92px;object-fit:cover;border-radius:8px;border:2px solid transparent}
  .pg-thumb.active img{border-color:#ff7a00}
</style>

<div class="pg-wrap">
  <div class="pg-main">
    <img id="pg-main" src="<%= imgs[0] || '' %>" alt="<%= (item&&item.title) || '' %>">
  </div>

  <% if (imgs.length > 1) { %>
    <div class="pg-thumbs">
      <% imgs.forEach(function(src, idx){ %>
        <button class="pg-thumb <%= idx===0 ? 'active' : '' %>" type="button" data-pg-src="<%= src %>">
          <img src="<%= src %>" alt="">
        </button>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
  (function(){
    const main = document.getElementById('pg-main');
    if(!main) return;
    const btns = document.querySelectorAll('.pg-thumb');
    btns.forEach(btn=>{
      btn.addEventListener('click', function(){
        const next = this.getAttribute('data-pg-src');
        if(next){ main.src = next; }
        document.querySelectorAll('.pg-thumb.active').forEach(b=>b.classList.remove('active'));
        this.classList.add('active');
      });
    });
  })();
</script>
