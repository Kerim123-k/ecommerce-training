<!-- views/shared/header.ejs -->
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= typeof title !== 'undefined' ? title : 'Training Shop' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<% // robust wishlist count (supports wishIds, wishCount, wishlistCount)
   const WL_COUNT = Number(
     (typeof wishlistCount !== 'undefined' && wishlistCount != null) ? wishlistCount :
     (typeof wishCount !== 'undefined'   && wishCount   != null) ? wishCount :
     (Array.isArray(wishIds) ? wishIds.length : 0)
   );
%>

<nav class="ts-nav">
  <div class="ts-nav__bar">
    <a class="ts-nav__brand" href="/products">Training Shop</a>

    <button class="ts-nav__toggle" type="button" aria-expanded="false" aria-controls="ts-links">Menu</button>

    <div id="ts-links" class="ts-nav__links">
      <% if (currentUser && currentUser.role === 'Admin') { %>
        <div class="ts-dropdown">
          <button class="ts-btn ts-pill" type="button">Admin</button>
          <div class="ts-menu">
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/products">Products</a>
            <a href="/admin/categories">Categories</a>
            <a href="/admin/coupons">Coupons</a>
            <a href="/admin/orders">Orders</a>
            <a href="/admin/reviews">Reviews</a>
          </div>
        </div>
      <% } %>

      <a href="/wishlist" class="ts-btn ts-pill" title="Wishlist">
        <span class="ts-heart <%= WL_COUNT > 0 ? 'is-on' : '' %>" aria-hidden="true">♥</span>
        <span class="ts-badge" data-wishlist-count><%= WL_COUNT %></span>
      </a>

      <a href="/cart" class="ts-btn ts-pill">
        Cart <span class="ts-badge"><%= Number(cartCount || 0) %></span>
      </a>

      <% if (currentUser) { %>
        <div class="ts-dropdown">
          <button class="ts-btn ts-pill" type="button">Account</button>
          <div class="ts-menu ts-menu--right">
            <div class="ts-menu__muted">Hello, <%= currentUser.name || currentUser.email %></div>
            <div class="ts-menu__sep"></div>
            <a href="/account">My Account</a>
            <a href="/account/orders">My Orders</a>
            <a href="/account/addresses">My Addresses</a>
            <div class="ts-menu__sep"></div>
            <form method="POST" action="/auth/logout">
              <button type="submit" class="ts-menu__btn">Logout</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="ts-btn">Login</a>
        <a href="/auth/register" class="ts-btn ts-btn--brand">Register</a>
      <% } %>
    </div>

    <span class="ts-nav__spacer"></span>
  </div>
</nav>

<% if (banner) { %>
  <div class="alert alert-warning container"><%= banner %></div>
<% } %>

<main class="container"><!-- keep your original container for page content -->

<style>
  /* ===== Header-only, namespaced styles (won't affect your pages) ===== */
  .ts-nav{border-bottom:1px solid #e5e7eb;background:#fff;position:sticky;top:0;z-index:50}
  .ts-nav__bar{max-width:1200px;margin:0 auto;padding:10px 16px;display:flex;align-items:center;gap:12px}
  .ts-nav__brand{font-weight:800;font-size:20px;color:#111;text-decoration:none}
  .ts-nav__spacer{flex:1}

  .ts-nav__links{display:flex;align-items:center;gap:10px}
  .ts-nav__toggle{display:none;border:1px solid #e5e7eb;background:#fff;border-radius:10px;padding:8px 10px;cursor:pointer}

  .ts-btn{display:inline-flex;align-items:center;gap:8px;border:1px solid #e5e7eb;background:#fff;color:#0f172a;
         padding:8px 12px;border-radius:10px;text-decoration:none;cursor:pointer}
  .ts-btn--brand{background:#2563eb;border-color:#2563eb;color:#fff}
  .ts-pill{background:#f8fafc}
  .ts-badge{min-width:22px;height:22px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;
            border:1px solid #e5e7eb;background:#fff;font-weight:600;color:#2563eb;padding:0 6px}
  .ts-heart{font-size:18px;color:#a3a3a3}
  .ts-heart.is-on{color:#e11d48}

  .ts-dropdown{position:relative}
  .ts-dropdown .ts-menu{
    position:absolute;top:100%;left:0;margin-top:6px;
    background:#fff;border:1px solid #e5e7eb;border-radius:12px;
    box-shadow:0 10px 30px rgba(2,6,23,.08);min-width:220px;padding:6px;display:none;z-index:1000
  }
  .ts-dropdown .ts-menu.ts-menu--right{left:auto;right:0}
  .ts-dropdown.open .ts-menu{display:block}

  .ts-dropdown .ts-menu a,
  .ts-dropdown .ts-menu .ts-menu__btn{
    display:block;width:100%;text-align:left;padding:10px 12px;border-radius:10px;
    border:none;background:transparent;color:#0f172a;text-decoration:none;cursor:pointer
  }
  .ts-dropdown .ts-menu a:hover,
  .ts-dropdown .ts-menu .ts-menu__btn:hover{background:#f8fafc}
  .ts-menu__muted{padding:8px 12px;color:#6b7280}
  .ts-menu__sep{height:1px;background:#e5e7eb;margin:6px}

  /* mobile */
  @media (max-width: 768px){
    .ts-nav__toggle{display:inline-flex}
    .ts-nav__links{display:none;flex-direction:column;align-items:flex-start;padding:10px 0}
    .ts-nav__links.open{display:flex}
  }
</style>

<script>
  // mobile menu toggle (scoped)
  (function(){
    const btn = document.querySelector('.ts-nav__toggle');
    const links = document.getElementById('ts-links');
    if (btn && links) {
      btn.addEventListener('click', function(){
        const open = links.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }
  })();

  // dropdowns: click-to-open (no hover gap), click outside to close
  (function(){
    document.querySelectorAll('.ts-dropdown > .ts-btn').forEach(btn=>{
      btn.addEventListener('click', (e)=>{
        e.stopPropagation();
        const dd = btn.parentElement;
        document.querySelectorAll('.ts-dropdown.open').forEach(x=>{ if(x!==dd) x.classList.remove('open'); });
        dd.classList.toggle('open');
      });
    });
    document.addEventListener('click', ()=> {
      document.querySelectorAll('.ts-dropdown.open').forEach(x=> x.classList.remove('open'));
    });
  })();
</script>
