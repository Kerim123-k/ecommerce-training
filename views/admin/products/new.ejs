<%- include('../../shared/header', { title: 'Admin • New product' }) %>

<h1>New product</h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/admin/products" enctype="multipart/form-data" class="vstack" style="gap:10px; max-width:700px;">
  <label>Title <input name="title" value="<%= values.title || '' %>" required></label>
  <label>SKU <input name="sku" value="<%= values.sku || '' %>"></label>
  <label>Price <input type="number" step="0.01" name="price" value="<%= values.price || 0 %>" required></label>
  <label>Status
    <select name="status">
      <option value="Draft">Draft</option>
      <option value="Active">Active</option>
      <option value="Archived">Archived</option>
    </select>
  </label>
  <label><input type="checkbox" name="trackInventory" checked> Track inventory</label>
  <label>Stock qty <input type="number" name="stockQty" value="<%= values.stockQty || 0 %>"></label>
  <label>Description
    <textarea name="description" rows="4"><%= values.description || '' %></textarea>
  </label>

  <fieldset style="border:1px solid #eee; padding:10px;">
    <legend>Primary image (optional)</legend>
    <input type="file" name="imageFile" accept="image/*">
  </fieldset>

  <button class="btn btn--brand" type="submit">Create</button>
  <a class="btn" href="/admin/products">Cancel</a>
</form>

<%- include('../../shared/footer') %>
