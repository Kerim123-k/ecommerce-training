<%- include('../../shared/header', { title: 'Admin • Edit product' }) %>

<h1>Edit: <%= p.title %></h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/admin/products/<%= p._id %>" enctype="multipart/form-data" class="vstack" style="gap:10px; max-width:700px;">
  <label>Title <input name="title" value="<%= p.title || '' %>" required></label>
  <label>SKU <input name="sku" value="<%= p.sku || '' %>"></label>
  <label>Price <input type="number" step="0.01" name="price" value="<%= p.price || 0 %>" required></label>
  <label>Status
    <select name="status">
      <option <%= p.status==='Draft'?'selected':'' %>>Draft</option>
      <option <%= p.status==='Active'?'selected':'' %>>Active</option>
      <option <%= p.status==='Archived'?'selected':'' %>>Archived</option>
    </select>
  </label>
  <label><input type="checkbox" name="trackInventory" <%= p.trackInventory!==false?'checked':'' %>> Track inventory</label>
  <label>Stock qty <input type="number" name="stockQty" value="<%= p.stockQty || 0 %>"></label>
  <label>Description
    <textarea name="description" rows="4"><%= p.description || '' %></textarea>
  </label>

  <% if (p.image) { %>
    <div class="muted">Current primary: <a href="<%= p.image %>" target="_blank"><%= p.image %></a></div>
  <% } %>
  <fieldset style="border:1px solid #eee; padding:10px;">
    <legend>Replace primary image (optional)</legend>
    <input type="file" name="imageFile" accept="image/*">
  </fieldset>

  <button class="btn btn--brand" type="submit">Save changes</button>
  <a class="btn" href="/admin/products">Back</a>
  <a class="btn" href="/admin/products/<%= p._id %>/images">Manage images</a>
</form>

<%- include('../../shared/footer') %>
