<!-- views/account/index.ejs -->
<%- include('../shared/header') %>

<h1>My Account</h1>

<div class="card" style="padding:16px; max-width:520px;">
  <p class="muted" style="margin-bottom:12px;">
    Signed in as <strong><%= (currentUser && (currentUser.name || currentUser.email)) || '' %></strong>
  </p>

  <div class="vstack" style="gap:10px;">
    <a class="btn" href="/account/orders">My Orders</a>
    <a class="btn" href="/account/addresses">My Addresses</a>
    <a class="btn btn--danger" href="/account/delete">Delete account</a>
  </div>
</div>

<%- include('../shared/footer') %>
