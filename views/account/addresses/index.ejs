<%- include('../../shared/header', { title: 'My Addresses' }) %>

<h1>My Addresses</h1>

<p><a class="btn" href="/account/addresses/new">+ Add address</a></p>

<% const list = addresses || []; %>
<% if (!list.length) { %>
  <p>No addresses yet.</p>
<% } else { %>
  <ul>
    <% list.forEach(a => { %>
      <li style="margin-bottom:10px;">
        <strong><%= a.fullName %></strong>
        <% if (a.isDefault) { %><span style="color:green"> (Default)</span><% } %><br/>
        <%= a.line1 %> <%= a.line2 || '' %>, <%= a.city %>, <%= a.postalCode %>, <%= a.country %><br/>
        <% if (a.phone) { %><small><%= a.phone %></small><br/><% } %>

        <a class="btn" href="/account/addresses/<%= a._id %>/edit">Edit</a>

        <form method="POST"
              action="/account/addresses/<%= a._id %>/delete"
              style="display:inline; margin-left:6px;"
              onsubmit="return confirm('Delete this address?')">
          <button class="btn btn--danger" type="submit">Delete</button>
        </form>

        <% if (!a.isDefault) { %>
          <form method="POST"
                action="/account/addresses/<%= a._id %>/default"
                style="display:inline; margin-left:6px;">
            <button class="btn" type="submit">Make default</button>
          </form>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('../../shared/footer') %>
