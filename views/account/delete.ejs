<%- include('../shared/header', { title: 'Delete account' }) %>

<h1>Delete my account</h1>
<p class="muted">This will permanently delete your account and anonymize your past orders. This action cannot be undone.</p>

<form method="POST" action="/account/delete" class="vstack" style="gap:12px; max-width:520px;">
  <div class="alert alert-warning">
    Are you sure you want to delete your account? This cannot be undone.
  </div>
  <button class="btn btn--danger" type="submit">Yes, delete my account</button>
  <a class="btn" href="/account/orders">Cancel</a>
</form>

<%- include('../shared/footer') %>
