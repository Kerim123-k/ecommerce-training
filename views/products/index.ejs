<%- include('../shared/header', { title: 'Shop' }) %>

<h1>Shop</h1>

<% if (!Array.isArray(products) || products.length === 0) { %>
  <p>No products found.</p>
<% } else { %>
  <div class="grid" style="display:grid; grid-template-columns: repeat(auto-fill,minmax(240px,1fr)); gap:18px;">
    <% products.forEach(p => { 
         const img = (Array.isArray(p.images) && p.images[0]) || p.image || '/placeholder.png';
         const price = Number(p.price || 0);
    %>
      <div class="card" style="border:1px solid #eee; border-radius:12px; overflow:hidden;">
        <a href="/p/<%= p.slug || ('id/' + p._id) %>" style="display:block;">
          <img src="<%= img %>" alt="<%= p.title %>" style="width:100%; height:180px; object-fit:cover;" />
        </a>
        <div style="padding:12px;">
          <a href="/p/<%= p.slug || ('id/' + p._id) %>"><strong><%= p.title %></strong></a>
          <div class="muted" style="margin:6px 0;">SKU <%= p.sku || '-' %></div>
          <div style="font-weight:700;">₺ <%= price.toFixed(2) %></div>
          <form method="POST" action="/cart/add/<%= p._id %>" style="margin-top:10px;">
            <input type="hidden" name="qty" value="1" />
            <button class="btn" type="submit">Add to cart</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../shared/footer') %>
