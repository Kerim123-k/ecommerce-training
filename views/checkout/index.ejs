<%- include('../shared/header') %>
<h1>Checkout</h1>
<% if (errors && errors.length) { %><div class="alert-error"><ul><% errors.forEach(e=>{ %><li><%= e.msg %></li><% }) %></ul></div><% } %>
<form method="POST" action="/checkout" class="form">
  <label>First name <input name="firstName" value="<%= (values&&values.firstName)||'' %>"></label>
  <label>Last name <input name="lastName" value="<%= (values&&values.lastName)||'' %>"></label>
  <label>Address line 1* <input name="line1" required value="<%= (values&&values.line1)||'' %>"></label>
  <label>Address line 2 <input name="line2" value="<%= (values&&values.line2)||'' %>"></label>
  <label>City <input name="city" value="<%= (values&&values.city)||'' %>"></label>
  <label>Province <input name="province" value="<%= (values&&values.province)||'' %>"></label>
  <label>Postal Code <input name="postalCode" value="<%= (values&&values.postalCode)||'' %>"></label>
  <label>Country <input name="country" value="<%= (values&&values.country)||'TR' %>"></label>
  <label>Phone <input name="phone" value="<%= (values&&values.phone)||'' %>"></label>
  <button type="submit">Place Order (Mock Payment)</button>
</form>
<%- include('../shared/footer') %>
