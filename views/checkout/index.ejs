<%- include('../shared/header') %>
<h1>Checkout</h1>

<% if ((addresses || []).length) { %>
  <form id="checkoutForm" method="POST" action="/checkout">
    <label>Shipping address</label>
    <select name="addressId">
      <% addresses.forEach(a => { %>
        <option value="<%= a._id %>" <%= a.isDefault ? 'selected' : '' %>>
          <%= a.fullName %> — <%= a.line1 %>, <%= a.city %> (<%= a.country %>)
        </option>
      <% }) %>
    </select>

    <h3>Cart</h3>
    <% const list = (cart && cart.items) || []; %>
    <% if (!list.length) { %>
      <p>Your cart is empty.</p>
    <% } else { %>
      <ul>
        <% list.forEach(i => { %>
          <li><%= i.qty %> × <%= i.title %> — ₺ <%= Number(i.unitPrice).toFixed(2) %></li>
        <% }) %>
      </ul>
      <p><strong>Subtotal:</strong> ₺ <%= Number(subTotal).toFixed(2) %></p>
      <button type="submit">Pay now (mock)</button>
    <% } %>
  </form>
<% } else { %>
  <p>No saved addresses. <a href="/account/addresses/new">Add one</a></p>
<% } %>

<%- include('../shared/footer') %>
