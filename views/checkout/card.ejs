<%- include('../shared/header', { title: 'Pay by card (Demo)' }) %>

<h1>Pay by card (Demo)</h1>
<p class="muted">This is a demo form—no real charges are made.</p>

<form method="POST" action="/checkout/card" class="vstack" style="gap:12px; max-width:980px;">
  <!-- keep these across the POST -->
  <input type="hidden" name="shippingMethod" value="<%= selectedShipping %>">
  <input type="hidden" name="discount" value="<%= Number(totals.discount||0) %>">

  <div class="grid" style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
    <label>Cardholder name*<input name="name" value="<%= (values && values.name) || '' %>" required></label>
    <label>Card number*<input name="number" placeholder="4242 4242 4242 4242" value="<%= (values && values.number) || '' %>" required></label>
    <label>Exp. month*<input name="expMonth" placeholder="MM" value="<%= (values && values.expMonth) || '' %>" required></label>
    <label>Exp. year*<input name="expYear" placeholder="YY" value="<%= (values && values.expYear) || '' %>" required></label>
    <label>CVV*<input name="cvv" placeholder="123" value="<%= (values && values.cvv) || '' %>" required></label>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert-error">
      <ul><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <h2>Order summary</h2>
  <div class="card" style="padding:12px; max-width:560px;">
    <div class="hstack" style="justify-content:space-between;">
      <span>Subtotal</span><strong>₺ <%= totals.subtotal.toFixed(2) %></strong>
    </div>

    <% if (Number(totals.discount || 0) > 0) { %>
      <div class="hstack" style="justify-content:space-between;">
        <span>Discount</span><span>- ₺ <%= Number(totals.discount).toFixed(2) %></span>
      </div>
    <% } %>

    <div class="hstack" style="justify-content:space-between;">
      <span>Tax</span><span>₺ <%= totals.tax.toFixed(2) %></span>
    </div>
    <div class="hstack" style="justify-content:space-between;">
      <span>Shipping</span>
      <span>₺ <%= totals.shipping.toFixed(2) %> (<%= (selectedShipping || totals.shippingMethod || 'standard') %>)</span>
    </div>
    <hr>
    <div class="hstack" style="justify-content:space-between; font-weight:600;">
      <span>Total</span><strong>₺ <%= totals.grandTotal.toFixed(2) %></strong>
    </div>
  </div>

  <div class="hstack" style="gap:10px;">
    <a class="btn" href="/checkout">Back</a>
    <button class="btn btn--brand" type="submit">Pay ₺ <%= totals.grandTotal.toFixed(2) %></button>
  </div>
</form>

<%- include('../shared/footer') %>
