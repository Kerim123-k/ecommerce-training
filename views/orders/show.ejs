<%- include('../shared/header') %>
<h1>Order <%= order.orderNo || order._id %></h1>

<p>
  <strong>Status:</strong> <%= order.status %><br/>
  <strong>Customer:</strong> <%= order.customerEmail || '-' %><br/>
  <strong>Placed:</strong> <%= new Date(order.createdAt).toLocaleString() %>
</p>

<%
  const sub   = order.totals?.subTotal ?? order.subtotal ?? 0;
  const grand = order.totals?.grandTotal ?? order.grandTotal ?? sub;
  const hasCancelReq = (order.timeline || []).some(t => t.status === 'Cancel Requested');
%>

<% if (hasCancelReq && !['Shipped','Delivered','Cancelled'].includes(order.status)) { %>
  <div class="card" style="padding:12px; margin:12px 0; border-left:4px solid #c00;">
    <strong>Customer requested cancellation.</strong>
    <form method="POST" action="/admin/orders/<%= order._id %>/cancel" style="display:inline; margin-left:8px;">
      <button class="btn btn--danger">Approve & cancel now</button>
    </form>
  </div>
<% } %>

<h3>Items</h3>
<table class="table">
  <thead>
    <tr><th>SKU</th><th>Title</th><th>Qty</th><th>Unit</th><th>Line</th></tr>
  </thead>
  <tbody>
    <% (order.items || []).forEach(i => { 
         const line = Number(i.qty) * Number(i.unitPrice || 0);
    %>
      <tr>
        <td><%= i.sku %></td>
        <td><%= i.title %></td>
        <td><%= i.qty %></td>
        <td>₺ <%= Number(i.unitPrice || 0).toFixed(2) %></td>
        <td>₺ <%= Number(line).toFixed(2) %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<p><strong>Subtotal:</strong> ₺ <%= Number(sub).toFixed(2) %><br/>
<strong>Total:</strong> ₺ <%= Number(grand).toFixed(2) %></p>

<p><a href="/admin/orders">← Back to list</a></p>
<%- include('../shared/footer') %>

<form method="POST" action="/admin/orders/<%= order._id %>/mark-paid" style="display:inline;">
  <button class="btn">Mark as Paid</button>
</form>
