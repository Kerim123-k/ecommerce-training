<%- include('../shared/header') %>

<h1>Order <%= order.orderNo %></h1>

<p><strong>Status:</strong> <%= order.status %></p>
<p><strong>Customer:</strong> <%= order.customerEmail || '—' %></p>
<p><strong>Placed:</strong> <%= new Date(order.createdAt).toLocaleString() %></p>

<h2>Items</h2>
<table class="table">
  <thead>
    <tr><th>SKU</th><th>Title</th><th>Qty</th><th>Unit</th><th>Line</th></tr>
  </thead>
  <tbody>
  <% (order.items || []).forEach(it => { %>
    <tr>
      <td><%= it.sku %></td>
      <td><%= it.title %></td>
      <td><%= it.qty %></td>
      <td>₺ <%= Number(it.unitPrice).toFixed(2) %></td>
      <td>₺ <%= Number(it.qty * it.unitPrice).toFixed(2) %></td>
    </tr>
  <% }) %>
  </tbody>
</table>

<p><strong>Subtotal:</strong> ₺ <%= Number(order.totals?.subTotal || order.subtotal || 0).toFixed(2) %></p>
<p><strong>Total:</strong>    ₺ <%= Number(order.totals?.grandTotal || order.total || 0).toFixed(2) %></p>

<hr/>

<h2>Actions</h2>

<% if (canProcess) { %>
  <form method="POST" action="/admin/orders/<%= order._id %>/process" style="display:inline">
    <button class="btn">Move to Processing</button>
  </form>
<% } %>

<% if (canShip) { %>
  <form method="POST" action="/admin/orders/<%= order._id %>/ship" style="display:inline; margin-left:8px">
    <input name="carrier" placeholder="Carrier" />
    <input name="trackingNumber" placeholder="Tracking #" />
    <button class="btn">Mark Shipped</button>
  </form>
<% } %>

<% if (canDeliver) { %>
  <form method="POST" action="/admin/orders/<%= order._id %>/deliver" style="display:inline; margin-left:8px">
    <button class="btn">Mark Delivered</button>
  </form>
<% } %>

<% if (canCancel) { %>
  <form method="POST" action="/admin/orders/<%= order._id %>/cancel"
        style="display:inline; margin-left:8px"
        onsubmit="return confirm('Cancel this order? Stock will be restored.')">
    <button class="btn">Cancel (refund mock)</button>
  </form>
<% } %>

<hr/>

<h3>Timeline</h3>
<ul>
  <% (order.timeline || []).forEach(t => { %>
    <li><%= new Date(t.at).toLocaleString() %> — <strong><%= t.status %></strong> <%= t.note ? ('— ' + t.note) : '' %></li>
  <% }) %>
  <% if (!(order.timeline || []).length) { %>
    <li>No timeline entries yet.</li>
  <% } %>
</ul>

<p><a href="/admin/orders">← Back to list</a></p>

<%- include('../shared/footer') %>
